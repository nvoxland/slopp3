{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/slopp\" --warm",
            "async": true,
            "timeout": 300,
            "statusMessage": "Warming the slopp jar cache"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c 'import json,sys,os; d=json.load(sys.stdin); os.makedirs(\".slopp\",exist_ok=True); open(\".slopp/pending-intent\",\"w\").write(d.get(\"prompt\",\"\"))' 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
