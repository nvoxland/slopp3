{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/slopp\" --warm",
            "async": true,
            "timeout": 300,
            "statusMessage": "Warming the slopp jar cache"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/prompt-hook.py\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/bash-smell-hook.py\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/bash-smell-hook.py\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c 'import json,sys,os,subprocess; d=json.load(sys.stdin); sid=d.get(\"session_id\",\"\"); os.path.exists(\".slopp/store.db\") and subprocess.run([os.environ.get(\"CLAUDE_PLUGIN_ROOT\",\"\")+\"/bin/slopp\",\"--call\",\"done\",json.dumps({\"agent\": sid, \"label\": \"session pause\"})], capture_output=True, timeout=280)' 2>/dev/null || true",
            "async": true,
            "timeout": 300,
            "statusMessage": "slopp: tidying + re-verifying your changes"
          }
        ]
      }
    ]
  }
}
