{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/slopp\" --warm",
            "async": true,
            "timeout": 300,
            "statusMessage": "Warming the slopp jar cache"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "plugin:slopp:slopp",
            "tool": "turn_begin",
            "input": {
              "agent": "claude",
              "intent": "${prompt}"
            },
            "timeout": 15,
            "statusMessage": "Opening the slopp turn"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "plugin:slopp:slopp",
            "tool": "turn_end",
            "input": {
              "agent": "claude"
            },
            "timeout": 15,
            "statusMessage": "Closing the slopp turn"
          }
        ]
      }
    ]
  }
}
