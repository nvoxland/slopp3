#!/bin/bash
# slopp CLI — the same release jar the MCP server runs, for direct use:
#   slopp <dir>                                serve MCP on a store (stdio)
#   slopp --call <tool> [json|edn|@file]       one-shot tool call, no session
#   slopp --main slopp.sync/-main import .     build the store from the repo's slopp branch
#   slopp --main slopp.sync/-main test .       isolated suite from a store build
#   slopp --doctor                             self-check the plugin wiring end-to-end
# Fetches and caches the versioned jar on first run; java 21+ required.
set -euo pipefail

VERSION="v0.1.2"
SHA256="85b1be6f7b274af7ac2bfaedeb35413f664a2e315a7b7f147399e133541849de"
JAR_URL="https://github.com/nvoxland/slopp3/releases/download/${VERSION}/slopp.jar"

CACHE="${CLAUDE_PLUGIN_DATA:-${XDG_CACHE_HOME:-$HOME/.cache}/slopp}"
JAR="$CACHE/slopp-${VERSION}.jar"

if ! command -v java >/dev/null 2>&1; then
  echo "slopp: no 'java' on PATH — install a JDK (Temurin 21+ recommended)" >&2
  exit 1
fi

checksum() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | cut -d' ' -f1
  else
    shasum -a 256 "$1" | cut -d' ' -f1
  fi
}

# --doctor: check the whole wiring in one command (Q6) — java, jar cache,
# hook/skill files, python3 (the hooks need it), and a live store probe.
# Exit 0 = everything an agent session needs is in place.
if [ "${1:-}" = "--doctor" ]; then
  rc=0
  say() { printf '%s %s\n' "$1" "$2"; }
  say "ok " "java: $(java -version 2>&1 | head -1)"
  ROOT="$(cd "$(dirname "$0")/.." && pwd)"
  for f in hooks/hooks.json skills/slopp/SKILL.md skills/slopp-setup/SKILL.md .mcp.json; do
    if [ -f "$ROOT/$f" ]; then say "ok " "plugin file: $f"; else say "FAIL" "plugin file missing: $f"; rc=1; fi
  done
  if command -v python3 >/dev/null 2>&1; then say "ok " "python3 (prompt/done hooks)"; else say "FAIL" "no python3 — the intent + done hooks will not fire"; rc=1; fi
  if [ -n "${SLOPP_JAR:-}" ]; then
    if [ -f "$SLOPP_JAR" ]; then say "ok " "SLOPP_JAR override: $SLOPP_JAR"; else say "FAIL" "SLOPP_JAR set but missing: $SLOPP_JAR"; rc=1; fi
  elif [ -f "$JAR" ]; then
    if [ "$(checksum "$JAR")" = "$SHA256" ]; then say "ok " "jar cached + checksum: $JAR"; else say "FAIL" "cached jar fails checksum: $JAR (delete it; the launcher refetches)"; rc=1; fi
  else
    say "warn" "jar not cached yet — first launch fetches ${VERSION} (~27MB); run 'slopp --warm'"
  fi
  [ -n "${SLOPP_LIVE:-}" ] && say "ok " "SLOPP_LIVE set — server tracks the store live"
  if [ -f ".slopp/store.db" ]; then
    if [ -n "${SLOPP_JAR:-}" ] || [ -f "$JAR" ]; then
      probe_jar="${SLOPP_JAR:-$JAR}"
      if out=$(java -jar "$probe_jar" --call query_namespaces 2>/dev/null | tail -1); then
        say "ok " "store probe: query_namespaces -> ${out:0:60}…"
      else
        say "FAIL" "store at .slopp/store.db but the probe call failed"; rc=1
      fi
    fi
  else
    say "warn" "no .slopp/store.db in $(pwd) — serving here starts empty (or auto-imports a slopp branch)"
  fi
  exit $rc
fi

# --warm: ensure the jar is cached, run nothing (the SessionStart hook uses
# this so the one-time download never races the MCP connection timeout).
WARM=0
if [ "${1:-}" = "--warm" ]; then
  WARM=1
  shift
fi

# Dev override: run a locally built jar (clojure -T:build uber) instead of
# the pinned release — no fetch, no checksum. For testing kernel/jar changes
# exactly as the plugin would run them.
if [ -n "${SLOPP_JAR:-}" ]; then
  [ "$WARM" = "1" ] && exit 0
  exec java -jar "$SLOPP_JAR" "$@"
fi

# Single-flight download: the SessionStart warm hook and the MCP server
# launch can both arrive on a cold cache — exactly one fetches (mkdir lock),
# everyone else waits for the jar to appear. A fetcher killed mid-download
# (the MCP client's 30s connect timeout does this) leaves a stale lock and a
# partial file: the next comer takes the lock over and curl RESUMES (-C -),
# so interrupted progress is never wasted. Checksum validates the whole
# file at the end regardless.
if [ ! -f "$JAR" ]; then
  mkdir -p "$CACHE"
  LOCK="$CACHE/fetch-${VERSION}.lock"
  PART="$JAR.part"
  attempts=0
  waiting_said=0
  while [ ! -f "$JAR" ]; do
    if mkdir "$LOCK" 2>/dev/null; then
      echo "$$" >"$LOCK/pid"
      attempts=$((attempts + 1))
      if [ "$attempts" -gt 3 ]; then
        rm -rf "$LOCK"
        echo "slopp: giving up fetching ${VERSION} after 3 attempts" >&2
        exit 1
      fi
      echo "slopp: fetching ${VERSION} from GitHub Releases (one-time, ~27MB)…" >&2
      curl -fsSL --retry 3 --retry-delay 1 -C - -o "$PART" "$JAR_URL" &
      cpid=$!
      echo "$cpid" >"$LOCK/curl"
      trap 'kill "$cpid" 2>/dev/null; rm -rf "$LOCK"' EXIT INT TERM
      if wait "$cpid"; then
        got="$(checksum "$PART")"
        if [ "$got" = "$SHA256" ]; then
          mv "$PART" "$JAR"
        else
          rm -f "$PART"
          echo "slopp: checksum mismatch for ${VERSION} (got $got) — refetching" >&2
        fi
      else
        rm -f "$PART"
        echo "slopp: download failed — retrying" >&2
      fi
      rm -rf "$LOCK"
      trap - EXIT INT TERM
    else
      owner="$(cat "$LOCK/pid" 2>/dev/null || true)"
      if [ -n "$owner" ] && ! kill -0 "$owner" 2>/dev/null; then
        # The fetcher died (e.g. SIGKILLed by the MCP connect timeout). Its
        # curl may have been orphaned and still be writing — take that out
        # too before stealing the lock, or we'd have two writers.
        ocurl="$(cat "$LOCK/curl" 2>/dev/null || true)"
        if [ -n "$ocurl" ]; then
          kill "$ocurl" 2>/dev/null || true
          sleep 1
        fi
        rm -rf "$LOCK"
        continue
      fi
      if [ "$waiting_said" = "0" ]; then
        echo "slopp: waiting for another slopp process to finish fetching ${VERSION}…" >&2
        waiting_said=1
      fi
      sleep 1
    fi
  done
fi

[ "$WARM" = "1" ] && exit 0

exec java -jar "$JAR" "$@"
